# Only values that must be set locally live here. Every other knob (base URLs,
# models, providers, endpoint templates, timeouts) already has a sane default in
# application.yml — add an override only if you actually need a non-default value.

# --- Database ---
POSTGRES_DB=saveapenny
POSTGRES_USER=saveapenny_app
POSTGRES_PASSWORD=change_me_local_only
DB_USERNAME=saveapenny_app
DB_PASSWORD=change_me_local_only

# --- Security ---
JWT_SECRET=change_me_to_a_64_plus_char_secret_for_hs512_signing_key

# --- AI Assistant (OpenRouter) ---
ASSISTANT_ENABLED=false
OPENROUTER_API_KEY=your_openrouter_api_key
OPENAI_API_KEY=

# --- Stocks (Alpha Vantage) ---
# Enabled by default in application.yml; forced off here until a key is set.
STOCK_ENABLED=false
ALPHA_VANTAGE_API_KEY=

# --- RevenueCat billing ---
REVENUECAT_ENABLED=false
REVENUECAT_SECRET_API_KEY=

# --- Firebase Analytics ---
FIREBASE_ANALYTICS_ENABLED=false
FIREBASE_ANDROID_APP_ID=
FIREBASE_ANDROID_API_SECRET=
FIREBASE_IOS_APP_ID=
FIREBASE_IOS_API_SECRET=

# --- Push notifications (FCM) ---
PUSH_FCM_ENABLED=false
# Firebase service-account JSON that project_id/client_email/private_key are read
# from directly (not via env vars). Defaults to the file on the classpath at
# src/main/resources/saveapenny-cc80fdf0c218.json (gitignored — add your own for
# local dev). Override for other environments, e.g. file:/etc/secrets/firebase.json
PUSH_FCM_CREDENTIALS_PATH=
